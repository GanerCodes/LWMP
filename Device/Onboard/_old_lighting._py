@micropython.native
def output_leds(leds,pinout,timing):
  bitstream(pinout,0,timing,leds)

class LED_Controller:
  __repr__ = lambda 𝕊: f"LED_Controller⟨{𝕊.dmode} lstate={𝕊.lstate}⟩"
  def __init__(𝕊,ℭ,𝔐):
    𝕊.ℭ,𝕊.lstate = ℭ,_LOOP_NEW_HW
    𝕊.scenes = Scene_Cacher(𝔐)
    𝕊.mode,𝕊.dmode,𝕊.𝔔 = None,None,[]
  
  def configure(𝕊,pin=23,order=(0,1,2),reverse=False,timing=(400,850,800,450)):
    if isinstance(timing,str): timing = tuple(map(int,timing.strip().split()))
    print(f"Configuring controller with {pin=} {order=} {reverse=} {timing=}")
    𝕊.dmode = pin,parse_rgb_mode(order),bool(reverse),tuple(timing)
    𝕊.lstate = _LOOP_NEW_HW
    return 𝕊
  
  def __call__(𝕊,s,q=False,d=inf,Ta=None,Ts=None):
    𝔔,s = 𝕊.𝔔,𝕊.scenes[s]
    
    has_max = 𝔔 or 𝕊.mode is not None
    get_max = lambda: max(𝔔) if 𝔔 else 𝕊.mode
    
    if d in (None,-1):
      d = inf
    if Ts is None and has_max:
      Ts = get_max().Ts
    if Ta is None:
      if q and has_max:
        mx = get_max()
        if mx.d == inf:
          Ta = mx.Ta
          𝕊.mode = None
        else:
          Ta = mx.Ta + mx.d
      else:
        Ta = Ts or 0
    if not q:
      h_from(X := [ν for ν in 𝔔 if not (Ta <= ν.Ta < Ta+d)]) # slow lol
      𝔔[:] = X
      # 󰤱 set as default background scene if dur == ∞ (? require that Ta is None)?
    m = Activation(Ta,Ts,s,d)
    print(f"Queing mode: {m}")
    h_add(𝔔,m)
    frees()
  
  def update_schedule(𝕊,schedule,reset=False,cache=set()):
    # https://www.desmos.com/calculator/0w2tpi3lci
    # also theoretically this has offset bugs with extremely specific conditions (submitting schedule like within seconds of it activating)
    𝔔 = 𝕊.𝔔
    
    if reset:
      cache.clear()
      𝔔[:] = [] # 󰤱
    
    now = time_μ()
    d = get_date(now)
    W = week_start(now)//1_000_000
    now //= 1_000_000
    
    T = now-W
    for Δ,(name,que,dur) in schedule.items():
      Δ = int(Δ)
      if (Δ-T)%s_per_w > s_per_d: continue
      A = W + Δ + (Δ<T)*s_per_w
      if A in cache: continue
      cache.add(A)
      A*=1000
      print(f"{name} is scheduled to activate at {A} ({W=})")
      𝕊(name,que,dur,A,A)
    
    return True
  
  ### @micropython.native
  def loop(𝕊,ms=ms,MS=MS):
    𝕊.lstate = max(𝕊.lstate,_LOOP_NEW_MODE)
    
    𝔔,ℭ = 𝕊.𝔔,𝕊.ℭ
    t,𝕊.mode = 0,None
    N,ΔS = 60,45*60
    pin=order=reverse=timing=None
    
    ### @micropython.native
    def get_wait_hwconf():
      while 𝕊.lstate and 𝕊.dmode is None: frees(0.1)
      p,order,reverse,timing = 𝕊.dmode
      pin = Pin(p)
      pin.init(pin.OUT)
      return pin,order,reverse,timing
    
    ### @micropython.native
    def get_mode():
      m = MS()
      # if 𝔔: print(f"it is {m}'o'clock my q is {𝔔}")
      while 𝔔:
        ν = 𝔔[0]
        if m < ν.Ta: return False
        h_pop(𝔔)
        if m >= ν.Ta+ν.d: continue
        return ν
    
    ### @micropython.native
    def get_Δ(m=None,T=None):
      S = 𝕊.mode and 𝕊.mode.Ts
      if S is None:
        if last_ntp[0] is None:
          return MS() % 86_400_000
      if m is None: m = ms()
      if T is None: T = MS()
      if S is None: S = week_start(T*1000) // 1_000
      # if abs(T-S) >= 60**2 * 1000: return -m # request ≥ an hour out of date
      return T-S-m # ✣ ms+Δ = 0 ⟺ T=S
    
    𝕒_ptr = Ѧ(𝕒_static := bytearray(36))
    leds = b'\0'*3*2048 # hard limit b/c i can't be bothered
    while 𝕊.lstate:
      try:
        while lstate := 𝕊.lstate:
          if lstate >= _LOOP_NEW_HW:
            if lstate == _LOOP_PAUSE:
              frees()
              while 𝕊.lstate == _LOOP_PAUSE:
                sleep(1)
              continue
            pin,order,reverse,timing = get_wait_hwconf()
            frees()
          if m := get_mode():
            𝕊.mode = m
            free()
            (S_,S_len,atoms,stk),(l,h) = specify_mode(*𝕊.mode.s,ℭ)
            ledv = memoryview(leds)[:3*(h-l)]
            tq = (ms()+(Δ := get_Δ()))//1000
            t_R,t_S,n = tq+1,tq+ΔS,0
            𝕒_static[:] = struct.pack("iiiiiiiii",Ѧ(S_),S_len,Ѧ(atoms),Ѧ(stk),Ѧ(leds),order,reverse,l,h)
            𝕊.lstate = _LOOP_TIGHT
            free()
          elif not 𝕊.mode:
            frees(0.1)
            continue
          
          tq,tr = divmod(ms()+Δ,1000)
          assign_leds(𝕒_ptr,tq+tr*0.001)
          output_leds(ledv,pin,timing)
          
          n+=1
          if not n%N or tq>=t_R:
            frees()
            if tq<t_R: continue
            now,m,T = time(),ms(),MS()
            log(f"{tq:04}.{tr:04}: FPS={n:6.2f} mem={mem_perc()} [{t_R},{t_S}] {fmt_date(now)} ({(T-(𝕊.mode.Ts or 0))/1_000_000})")
            if 𝔔: log("\t𝔔: "+join(f"[{ν.d} {ν.Ta} {ν.Ts}]" for i,ν in enumerate(𝔔)))
            if tq>=t_S:
              ntp_sync() # 󰤱 add this to other thread loop instead
              t_S = (tq := (ms()+(Δ := get_Δ()))//1000)+ΔS
            else:
              tq = (m+(Δ := get_Δ(m=m,T=T)))//1000
              if tq>=t_S: t_S = tq+ΔS
            log(f"\t{Δ=}")
            t_R,n = tq+1,0
      except Exception as ε:
        dbg(f"Error in LED loop! Restarting in 3 seconds:",ε)
        frees(3)
  
  def pause(𝕊):
    s = 𝕊.lstate
    𝕊.lstate = _LOOP_PAUSE
    return lambda: setattr(𝕊,"lstate",s)

__all__ = "LED_Controller",