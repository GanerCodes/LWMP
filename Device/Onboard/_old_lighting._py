from util          import *
from timing        import *
from interface     import *
from lightwave     import *
from scene_manager import *

_LOOP_NONE     = const(0)
_LOOP_TIGHT    = const(1)
_LOOP_NEW_MODE = const(2)
_LOOP_NEW_HW   = const(3)
_LOOP_PAUSE    = const(5)

Activation = namedtuple("Activation",["Ta","Ts","s","d"])

