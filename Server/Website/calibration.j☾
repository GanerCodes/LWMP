led_calibrate = 󰇮(⥌𝘴,𝘳↦󱟱⥌𝐝,cb↦{
  © SCENE_CALIB = 󰲡({"*":[{1:[x,0,0xFF00]},{1:[1001-x,0,0xFF0000]}                 ]});
  © SCENE_FINAL = 󰲡({"*":[{1:[1,0,0xFF00]},{1:[   x-2,0,0       ]},{1:[1,0,0xFF00]}]});
  © MSG = ‹Is red visible at the end of the LED strip?›;
  
  󱫬 𝐝.config({LEDC:1000});
  ⎉ 𝔖 = [[1,100,1000]];
  ➰(✓) { ⎉ [l,m,h] = 𝔖􋕛(󷰾);
         󱫬 𝐝.scene(‹_calib›,SCENE_CALIB(m),✗,󷰾)
         𝘴(m,MSG,[⠤🃌(𝔖)>1⭜[␛󷹁]⭝[],‹No›,‹Yes›]);
         ⎉ r = 󱫬 𝘳();
         ¿(r≡‹󷹁›) { 𝔖.pop(); ↺; }
         ¿(l<h  ) { ¿(r≡‹No›) h = m;
                    ¡         l = m+1;
                    m = ~~((l+h)/2); }
         ¿(l≡h  ) { 󱫬 𝐝.bulk(["config", {LEDC:m}                   ],
                             ["scene" , ‹_calib›,SCENE_FINAL(m),✗,󷰾]);
                    𝘴();
