RGB_calibrate = 󱟱 ⥌𝐝↦{
  ⎉ C = [⠤"RGB"];
  󱫬 𝐝.config({RGB_ORDER:"RGB"});
  󱫬 𝐝.scene({ _singlecolor0: {"fx":[[2,0.25]],"1":[300,0,0xFF<<16]},
              _singlecolor1: {"fx":[[2,0.25]],"1":[300,0,0xFF<< 8]} });
  󱫬 𝐝.scene(‹_singlecolor0›,✗,󷰾);
  ↪[C,󱟱⥌α↦{ C = C􋐉(󰲡x≠α);
            󱫬 𝐝.scene(‹_singlecolor1›,✗,󷰾);
            ↪[C,󱟱⥌β↦{ C = C􋐉(󰲡x≠β)₀+β+α;
                      󱫬 𝐝.config({RGB_ORDER:C});
                      ↪C }]; }]; };

 [C,ƒ] = 󱫬 RGB_calibrate(𝐝)
  user chooses from C
 ⎉ [C,ƒ] = 󱫬 ƒ(choice)
