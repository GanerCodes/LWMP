RGB_calibrate = 󱟱 ⥌𝐝↦{
  ⎉ C = [⠤"RGB"];
  󱫬 𝐝.bulk(["config", { RGB_ORDER:"RGB" }],
           ["scene" , { _singlecolor0: {fx:[[2,0.25]],1:[300,0,255<<16]},
                        _singlecolor1: {fx:[[2,0.25]],1:[300,0,255<< 8]} }],
           ["scene" , ‹_singlecolor0›,✗,󷰾]);
  ↪[C,󱟱⥌α↦{ C = C􋐉(󰲡x≠α);
            󱫬 𝐝.scene(‹_singlecolor1›,✗,󷰾);
            ↪[C,󱟱⥌β↦{ C = α+β+C􋐉(󰲡x≠β)₀;
                      󱫬 𝐝.config({RGB_ORDER:C});
                      ↪C }]; }]; };

