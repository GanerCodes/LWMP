⎉ ətileButton = ⥌t,cb↦󱀝 div {𝐶 bigButton⍮ 𝑆 ⟦fit_size(t,250)⟧⍮ onclick ⟦󰲟cb(t)⟧} ⟦t⟧

⎉ ətokenListing = ⥌cb↦{
  © prompt_token = ⥌cb↦{
    © fld = textField({id:‹tokenField›,𝑃𝐻:‹Token›,:✓});
    ©  = popup({:✓,󰅙:✓},
                ətitledBox(
                  ‹Enter token to add›,
                  󱀝 div {𝐶 tokenAddBox⍮ 𝑆 ⦅𝚠≤ ⅘;𝚏↓⦆} ⟦[
                    fld,
                    textButton(‹Submit›,󰲟{.close();cb(fld􀲫.value)})]⟧,
                  {outline:✗})); };
  ©  = əitemGridEditable(
          ⥌  gen↦prompt_token(󰲡(add_check_tok(x),gen(x))),
          ⥌x,rem↦[ətileButton(x,cb),əbuttonBar([␛󰆴,rem])],
          del_tok);
  ᵖᵒᵖᵘˡᵃᵗᵉ = ⥌𝐓↦{ .clear_items();
                   𝐓􋁃(󰲡ᵃᵈᵈ􋕟ⁱᵗᵉᵐ(x)); }
  ↪; }

⎉ ədevListing = 󰲟{
  © 𝔖 = {};
  © ədevTile = ⥌𝐮,𝐝↦{
    ©  = 󱀝 div ⦅𝚏↓;󰊄𝚜 30px⦆ [
            󱀝 T ⦅󰊄𝚜 40px⦆ ‹⟦𝐮⟧ ⟦[‹🔴›,‹🟢›]₊􊳜􊫺􊬢􊫂􊬖􊬢􊫶⟧›
            󱀝 T ‹⟦𝐝ᴿᴳᴮ􋕟ᴼᴿᴰᴱᴿ⟧ - ⟦𝐝ᴸᴱᴰ󰀂⟧ LEDs (⟦"→←"₊􊳜􊫯􊫤􊲍􊫤􊫯􊻐􊫤⟧)›]
    ↪ };
  ©  = əitemGridEditable(
          󱣩,
          ⥌x,rem↦[ədevTile(⠤x),
                  əbuttonBar(
                    [␛󰆴,rem                                               ],
                    [␛,󰲟prompt_rgb_calibrate(𝐀(𝔖􋆮,x₀),󰲡(x,ᵖᵒᵖᵘˡᵃᵗᵉ(𝔖􋆮)))],
                    [␛,󰲟prompt_led_calibrate(𝐀(𝔖􋆮,x₀),󰲡(x,ᵖᵒᵖᵘˡᵃᵗᵉ(𝔖􋆮)))],
                    [␛󰐥,󰲟𝐀(𝔖􋆮).dev(x₀).off()                              ])],
          󰲡☾(‹Removing ⟦x⟧›),
          [],
          { show_plus  : ✗,
            placeholder: 󰲟󱀝 h2 ‹No devices found for this token...› })
  ᵖᵒᵖᵘˡᵃᵗᵉ = 󱟱 ⥌𝐭↦{ 𝔖􋆮 = 𝐭;
                     ⎉ devs = 󱫬 load_devices(𝔖􋆮);
                     devs = devs₁;
                     .clear_items();
                     𝒪(devs)􋁃(󰲡ᵃᵈᵈ􋕟ⁱᵗᵉᵐ(x)); };
  ↪; };

⎉ əsceneListing = ⥌cb↦{
  © 𝔖 = {};
  © prompt_scene = ⥌cb,Ѧ={name:ᐦ,𝐔:[],dat:{}}↦{
    © fld = textField({𝑃𝐻:‹Scene Name›,value:Ѧⁿᵃᵐᵉ});
    © get = 󰲟({⠤Ѧ,name:fld􀲫.value});
    ©  = popup({:✓,󰅙:✓},
                ətitledBox(
                  ‹Scene details›,
                  󱀝 div {𝐶 tokenAddBox⍮ 𝑆 ⦅𝚠≤ ⅘;𝚏↓⦆} ⟦[
                    fld,
                    textButton(‹Submit›,󰲟{.close();cb(get())})]⟧,
                  {outline:✗})); };
  ©  = əitemGridEditable(
          ⥌  gen↦prompt_scene(
                   ⥌𝐬↦{ ¿(¬add_scene(𝔖􋆮,𝐬))
                         ↪☾(‹Scene already exists ⟦x⟧‽›);
                        gen(𝐬); }),
          ⥌𝐬,rem↦[ətileButton(𝐬ⁿᵃᵐᵉ,cb),
                  əbuttonBar(
                    [␛󰆴,rem],
                    [␛,󰲟prompt_scene(
                      ⥌𝚗↦{ rem(𝐬);
                           add_scene(𝔖􋆮,𝚗,✓);
                           ᵃᵈᵈ􋕟ⁱᵗᵉᵐ(𝚗); },
                      𝐬)])],
          ⥌𝐬    ↦move_scene(𝔖􋆮,𝐬ⁿᵃᵐᵉ));
  ᵖᵒᵖᵘˡᵃᵗᵉ = ⥌𝐭↦{ [𝔖􋆮,𝔖􋆄] = [𝐭,get_devs(𝐭)];
                   .clear_items();
                   𝒪(get_scenes(𝐭))􋅝(⥌name,y↦ᵃᵈᵈ􋕟ⁱᵗᵉᵐ({name,⠤y})); };
  ↪; }