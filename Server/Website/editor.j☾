© scene_count = ⥌M↦isArr(M) ⭜M₁   ⭝
                      ␛1∈M  ⭜M􊯛₁ ₀⭝
                      M􊯛􊾡(󰲡scene_count(x))􋔩(󰲣x+y);  󰤱􊽨 make this cache
©  = 󰲡‹rgb(⟦x>>16&0xFF⟧,⟦x>>8&0xFF⟧,⟦x>>0&0xFF⟧)›;

prompt_editor = ⥌cb,𝔖,𝐬↦{
  © names  = 𝐬􋆕 􊾡(󰲡𝔖􋆄ₓ⸮NAME??x);
  © counts = 𝐬􋆕 􊾡(󰲡𝔖􋆄ₓᴸᴱᴰ󰀂);
  © ctot   = counts􋔩(󰲣x+y,0);
  
  © dat𝘏 = [];
  
  ⎉ labels,dat,inspect;
  ©  = popup({󰅙:✓, noAppend:✓},
              󱀝 {𝐶 𝘌outer} [
                󱀝 h2 ‹Scene Editor - ⟦ctot⟧ Pixels›
                󱀝 {𝐶 𝘌inner} [
                  󱀝 {𝐶 𝘌preview} [
                    󱀝 {} [
                      󱀝 {} [
                        󱀝:labels {𝐶 𝘌alignedLabels}
                        󱀝         {𝐶 𝘌pixels       } [󱀝:dat {}]]]]
                  󱀝 {𝐶 vertBar⍮ ⦅𝚠 10px⦆} ‹›
                  󱀝:inspect {}]]);
  􋒅 ⁺(‹editorDialog›);
  © render = ⥌dat,outer=✓↦{
    ☾(‹render(⟦𝔍􋀫(dat)⟧, ⟦outer⟧)›);
    dat𝘏.push(dat);
    
    © stot  = scene_count(dat);
    © scale = 󰲡⤉(2,400/stot)⋅x;
    
    © render_𝖬 = ⥌M,n=0↦{
      © render_atom = ⥌[n,i,⠤M]↦{
        © 𝗆 = 󰲡󱀝 {𝐶 𝘌atom⍮ 𝑆 ⟦⦅𝚑 ⟦scale(n)⟧px⦆+␛;+x⟧} ‹› 
        ¿(i≡0) {
          © [𝚌] = M;
          ↪𝗆(⦅𝚋 ⟦(𝚌)⟧⦆); }
        ⸘(i≡1) {
          © [seg,sat,val] = M;
          © 🌈 = ‹linear-gradient(180deg in hsl longer hue, hsl(0,100%,50%), hsl(360,100%,50%)) 0 0 / ⟦100/seg⟧% 100% repeat-x›;
          ↪𝗆(⦅background ⟦🌈⟧⦆); };
        ↪‹󰤱›; };
      © render_tick = ⥌𝚒,m=40,b=20↦{
        © [p,s] = [⤉(1,3÷𝚒)    , b+m÷𝚒];
        © [l,α] = [255-40⋅(𝚒-1), 100  ];
        © clr = ‹rgba(⟦l⟧,⟦l⟧,⟦l⟧,⟦α⟧%)›;
        © cnd = 𝚒>1⭜‹;pointer-events:none›⭝ᐦ;
        ↪󱀝 {𝐶 𝘌tickmark⍮ 𝑆 ⟦⦅𝚋 ⟦clr⟧; 𝚠 ⟦s⟧px; «𝚑 𝚑≥» ⟦p⟧px; 𝚖↓ ⟦-p⟧px⦆+cnd⟧} ‹›; };
      
      © isAtom = isArr(M);
      ⎉ C = isAtom ⭜[render_atom(M  )]⭝
             ␛1∈M  ⭜[render_atom(M􊯛₁)]⭝
                    M􊯛􊾡(󰲣render_𝖬(x,n+1));
      C = C􊾡(󰲣(xⁱᵈˣ=y,x));
      ¿(C􋌵>1) C = C􌿑􋇙(󰲟render_tick(n+1));
      ⎉  = 󱀝 div {𝐶 𝘌modes} ⟦C⟧;
      
      ¿(¬isAtom ∧ (n≡0 ∧ C􋌵>1 ∨ C₀􋌵>1)) {
        C􋁃(⥌c↦{
          c = dragItem(c,n,󰲣{
            swapə(x,y);
            © d = dat􊯛;
            [dₓ􊬖􊫵􊫄,d􊬖􊫵􊫄] = [d􊬖􊫵􊫄,dₓ􊬖􊫵􊫄];
            render(dat,outer); });
          c.onclick = 󰲟render(dat􊯛 􋑴􊬖􊫵􊫄, ✗); }); }
      ⸘(n>1) 􋛟 ᵖᵒⁱⁿᵗᵉʳᴱᵛᵉⁿᵗˢ = ‹none›;
      ¿(n≡0) { ⁱᵈˣ = 0;
               © x = (⥌𝚚,=󰈙↦[⠤.matches(𝚚)⭜[]⭝[],⠤QSA(𝚚,)])(‹.𝘌atom›,);
               ☾(,x);
               x₀   􋛟.borderTopRightRadius    = ‹10px›;
               x􋕛(󷰾)􋛟.borderBottomRightRadius = ‹10px›; }
      
      ↪; };
    
    © set_inspector = ⥌↦{
        󷸾   󱦙 󰳲
      © fx_og = grp_fx(dat);
      © fx = {0:[], 1:[1,0], 2:[1], ⠤fx_og};
      
      © show = 󰲣x􋛟.display=y⭜ᐦ⭝‹none›;
      © fx_togs = {
        rev: [toggleButton(󰻾                   ,␛,␛,✗,{init:✗,polar:✗})],
        rot: [toggleButton(󰲡show(fx_togsʳᵒᵗ₁,x),␛󱦙,␛󱦙,✗,{init:✗}),
              (󰲟{ ⎉ [speedl,offstl] = [󱀝 T ‹›,󱀝 T ‹›];
                  © speed = əslider({l:󷰿󷰽󷰽 ,v:fx􊯛₁ ₀,h:200 ,s:0.1,
                                       ƒ:󰲡speedl􋒷=‹⟦fx􊯛₁ ₀=x⟧ Pixels/s›});
                  © offst = əslider({l:󷰾󷰽󷰽󷰽,v:fx􊯛₁ ₁,h:1000,s:1  ,
                                       ƒ:󰲡offstl􋒷=‹⟦fx􊯛₁ ₁=x⟧ Pixels›  });
                  ↪󱀝 {𝐶 𝘌fxSection} [
                     󱀝 label ‹Rotation›
                     󱀝 [󱀝 label ‹Speed󷺗› ⟦speedl⟧ ⟦speed⟧]
                     󱀝 [󱀝 label ‹Offset› ⟦offstl⟧ ⟦offst⟧]]; })()],
        lum: [toggleButton(󰲡show(fx_togsˡᵘᵐ₁,x),␛󰳲,␛󰳲,✗,{init:✗}),
              (󰲟{ ⎉ luml = 󱀝 T ‹›;
                  © lum = əslider({l:0,v:fx􊯛₂ ₀⋅255,h:255,s:1,
                                     ƒ:󰲡luml􋒷=‹⟦⬓((fx􊯛₂ ₀=x÷255)⋅100)⟧%›});
                  ↪󱀝 {𝐶 𝘌fxSection} [
                     󱀝 label ‹Brightness› ⟦luml⟧ ⟦lum⟧ ]; })()] };
      
      © fx_names = [‹rev›,‹rot›,‹lum›];
      fx_names􋁃(󰲣fx_togsₓ ₀.set(y∈fx_og));
      
      © update_fx_dat = 󰲟{
        
      }
      
      
      inspect.replaceWith(inspect = 
        󱀝 {𝐶 𝘌inspector} [
          󱀝 label ‹Effects›
          󱀝 span {𝐶 𝘌toggleSection} ⟦𝒪v(fx_togs)􋅝(󰲣x􋑵)⟧
          ⟦𝒪v(fx_togs)􊾡􎘌(󰲡x􋌵≡2⭜[x₁]⭝[])⟧]); };
    
    dat.replaceWith(dat = render_𝖬(dat));
    set_inspector(dat);
    
    © ətriLabel = ⥌n,⠤𝔸↦
      󱀝 {⦅𝚑≥ ⟦scale(n)⟧px⦆} [
        󱀝 {} ⟦𝔸⟧
        󱀝 svg {viewBox ‹-1.05 -1 2 2›⍮ preserveAspectRatio ‹none›} [
          󱀝 path {d ‹M1 -1 L-1 0 L1 1›⍮ style ‹fill:#0000;stroke:#FFF;stroke-width:0.05›} ‹›]]
    labels.replaceChildren(⠤outer ⭜ ↨(󱑼(names,counts))􋅝(⥌i,[𝐧,n]↦ətriLabel(n, 󱀝 T ‹⟦𝐧⟧›, 󱀝 T ‹⟦n⟧ Pixels›))
                                   ⭝ ətriLabel(stot, 󱀝 T ‹⟦stot⟧ Pixels›));
  };
  
  render(dat);
  
  󰈙.body􍪙(); .showModal();
   cb(𝐬);
};