@font-face вҲЈ у°Ҡ„рқҡҸ "Avenir";
             src url("/Assets/Avenir.woff2")
@font-face вҲЈ у°Ҡ„рқҡҸ "Symbols"
             src url("/Assets/Symbols.woff2")
о¬Ұ format("woff2")

:root вҲЈ у°Ҡ„рқҡҸ "Symbols","Avenir"

* вҲЈ рқҡғ background-color 0.2s ease

::-webkit-scrollbar-thumb  вҲЈ оҲ«рқҡӢ #847
                             рқҡӢрқҡӣ 100px
::-webkit-scrollbar-thumbфҚіө вҲЈ оҲ«рқҡӢ #A58
::-webkit-scrollbar-thumbфҖҙ— вҲЈ оҲ«рқҡӢ #B59
::-webkit-scrollbar        вҲЈ рқҡ  1vw 

body вҲЈ рқҡҸвҶ“;рқҡҠрқҡӮу··Ј;рқҡқрқҡҠу··Ј;рқҡ–0

.icon вҲЈ рқҡ‘ 0.75em
        vertical-align center
.box вҲЈ рқҡӢрқҡӣ .5vw

.В«hbar bigButtonВ»
  рқҡ ;рқҡ–0;рқҡҠрқҷҝу··Ј;рқҡҠрқҡӮу··Ј
  пҮҚфҺҒҺ вҲЈ оҲ«рқҡӢ #111; рқҡ–рқҡҷ pointer
  пҮҚфҖҙ— вҲЈ оҲ«рқҡӢ #222
.multiButtonBar
  рқҡҸвҶ’;рқҡ ;рқҡ–0;рқҡҠрқҷҝe;рқҡҠрқҡӮу··Ј;рқҡ–вҶ‘a

.В«barButton bigButtonВ»
  рқҡ ;рқҡ‘; у°Ҡ„рқҡҠ center
.barButton вҲЈ рқҡ 
             пҮҚ>* вҲЈ рқҡҠрқҡӣ 1; рқҡ‘Вҫ
             у°Ҡ„рқҡң 40px
.bigButton вҲЈ рқҡҸвҶ“; рқҡҠрқҷҝу··Ј; рқҡҠрқҡңу··Ј; у°Ҡ„рқҡң 290px
.itemGrid вҲЈ рқҡҚ grid; рқҡ ; рқҡ‘вүӨ 90vh
            рқҡҠрқҷҝу··Ј; рқҡҗ 20px
            grid-template-columns repeat(auto-fit,300px)
            пҮҚ>.itemGridPlaceholder
              рқҡҚ фӢ„…
            пҮҚфҠҪ¬вҒҪфӢҒӢвҒҪу°ӮҒфҠҪ¬вҒҪфӢҒ•вҒҪ.itemGridAdderу°Ғұ.itemGridPlaceholderвҒҫвҒҫвҒҫвҒҫ
              рқҡҸ
              пҮҚ>.itemGridPlaceholder вҲЈ В«рқҡ вүӨ рқҡ  рқҡ вүҘВ» 100%; рқҡҚ unset; рқҡӢ фӢ„…
.itemGridItem вҲЈ рқҡҸвҶ“; В«рқҡ вүӨ рқҡ  рқҡ вүҘ рқҡ‘вүӨ рқҡ‘ рқҡ‘вүҘВ» 300px
                рқҡӢ 2px solid #EEE; рқҡӢрқҡӣ 10px
                пҮҚ>.multiButtonBar вҲЈ рқҡӢвҶ‘ 2px solid #EEE

.rgbButtons
  пҮҚ>* вҲЈ В«рқҡ  рқҡ‘В» 10vw
        line-height 0
        рқҡҚ inline-flex;рқҡҠрқҷҝу··Ј;рқҡҠрқҡӮу··Ј
        рқҡ– 1vw
        рқҡҷ 20px
        рқҡӢ 2px solid #EEE; рқҡӢрқҡӣ 1000px
        у°Ҡ„рқҡң 8vw; font-weight bold
        пҮҚ[c="R"] вҲЈ рқҡӢ 6px solid #F00
                   пҮҚ  вҲЈ оҲ« #DD2222; оҲ«рқҡӢ #100000
                   пҮҚфҺҒҺ вҲЈ оҲ« #EE2222; оҲ«рқҡӢ #200000
                   пҮҚфҖҙ— вҲЈ оҲ« #FF3333; оҲ«рқҡӢ #300000
        пҮҚ[c="G"] вҲЈ рқҡӢ 6px solid #0F0
                   пҮҚ  вҲЈ оҲ« #22DD22; оҲ«рқҡӢ #001100
                   пҮҚфҺҒҺ вҲЈ оҲ« #22EE22; оҲ«рқҡӢ #002000
                   пҮҚфҖҙ— вҲЈ оҲ« #33FF33; оҲ«рқҡӢ #003000
        пҮҚ[c="B"] вҲЈ рқҡӢ 6px solid #00F
                   пҮҚ  вҲЈ оҲ« #2222DD; оҲ«рқҡӢ #000010
                   пҮҚфҺҒҺ вҲЈ оҲ« #2222EE; оҲ«рқҡӢ #000020
                   пҮҚфҖҙ— вҲЈ оҲ« #3333FF; оҲ«рқҡӢ #000030

.ledCalbButtons
  пҮҚ>* вҲЈ В«рқҡ  рқҡ‘В» 7vw
  рқҡӢ 2px solid #EEE; рқҡӢрқҡӣ 5px 
  у°Ҡ„рқҡң 3vw

.navContainer  вҲЈ рқҡ 
                 рқҡҳрқҡҸx hidden
                 пҮҚ>.multiButtonBar
                    рқҡ‘вүӨ 10vh

.navBodyHolder вҲЈ рқҡ ; рқҡ‘вүӨ calc(90vh - 30px)
                 рқҡ–вҶ‘ 30px; рқҡҳрқҡҸy scroll
.devDraggableHolder вҲЈ рқҡҸвҶ“;рқҡ ;рқҡ‘;у°Ҡ„рқҡң 22px
                      рқҡӢ 1px solid #555
                      пҮҚ[maydrop]  вҲЈ рқҡӢ 1px dashed #FF0
.devDraggable       вҲЈ рқҡ ;рқҡҸвҶ’;рқҡҠрқҷҝb;рқҡҠрқҡӮу··Ј;рқҡҷу··ў 5%
                      рқҡӢ 1px solid #555
                      пҮҚ[maydrop]  вҲЈ рқҡӢ 1px dashed #FF0
                      пҮҚ[dragging] вҲЈ рқҡғрқҡҸ scale(0.75)
.titledBox вҲЈ рқҡ вүҘ 80%;рқҡҸвҶ“;рқҡҠрқҡӮу··Ј
.promptBox
  рқҡҠрқҡӮу··Ј
  пҮҚ>h1 вҲЈ у°Ҡ„рқҡң 50px
  пҮҚ>.boxInput
    рқҡ–вҶ“ 30px
    пҮҚ>* вҲЈ у°Ҡ„рқҡң 30px
  пҮҚ>button вҲЈ рқҡ  150px
             рқҡӢ 2px solid #999; рқҡӢрқҡӣ 5px
             у°Ҡ„рқҡң 40px