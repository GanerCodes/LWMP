əitemGridEditable = ⥌plus,gen,rem,items=[],Ѧ={show_plus:✓,placeholder:󱣩}↦{
  ⎉ ε,ε_adder;
  󱀝:ε {𝐶 itemGrid} [
      󱀝:ε_adder {𝐶 itemGridItem itemGridAdder} [
          ⟦əbigButton(␛+, {onclick:𝚲plus(ε.add_item)})⟧ ] ];
  ε.add_item = 󰲣{ ⎉ newElm = 󱀝 div {𝐶 itemGridItem};
                  ¿(y) { newElm􋒅 ⁺(‹itemGridPlaceholder›);
                         chainIntoElements(x, newElm); }
                  ¡    { chainIntoElements(gen(x,𝚲(rem(x),newElm.remove())), newElm); }
                  newElm􌿱 = newElm􋑱₀
                  ε.insertBefore(newElm,ε_adder); };
  ¿(Ѧᵖˡᵃᶜᵉʰᵒˡᵈᵉʳ≇󱣩) ε.add_item(Ѧᵖˡᵃᶜᵉʰᵒˡᵈᵉʳ(),✓);
  ε.clear_items = 𝚲QSA(‹:scope > :not(:is(.itemGridAdder,.itemGridPlaceholder))›,ε)􊾡(󰲡x.remove())
  ε.set_plus = 󰲡ε_adder􋛟.display = x⭜‹unset›⭝‹none›;
  ε.set_plus(Ѧˢʰᵒʷ􋕟ᵖˡᵘˢ);
  items􋁃(ε.add_item);
  ↪ε; };

