𝔻 = ⥌↑=󰻾,↓=󰻾
    ↦({ ↑,↓,
        𝕀: 𝚲𝔻(↓,↑),
        𝕄: 𝚲𝔻(󰲡x􋅒()⋅↑(x􋄽()), 󰲡x􋅒()⋅↓(x􋄽())),
        𝕋: ⥌[l=0,r=1,b=↑(l),t=↑(r)]=[],
            [L=0,R=1,B=  L ,T=  R ]=[]
           ↦{ © 𜳩 = ⥌ƒ,l,r,b,t,L,R,B,T
                    ↦{ © [α,β] = [(T-B)÷(t-b),(r-l)÷(R-L)];
                       ↪󰲡B+α⋅(ƒ(l+β⋅(x-L))-b); };
              ↪𝔻(𜳩(↑,l,r,b,t,L,R,B,T),
                 𜳩(↓,b,t,l,r,B,T,L,R)); } });

əslider = ⥌Ѧ={}↦{
  Ѧ = {init:✓,𝕕:𝔻(),l:0,h:1,s:0,ƒ:󰻾,⠤Ѧ};
  
  ¿(¬(␛v∈Ѧ)) Ѧᵛ = Ѧˡ;
  [Ѧˡ,Ѧᵛ,Ѧʰ,Ѧˢ] = [+Ѧˡ,+Ѧᵛ,+Ѧʰ,+Ѧˢ];
  
   ©  = Ѧ􋑵 = 󱀝 input {𝑇 ‹range›⍮ min ⟦Ѧˡ⟧⍮ defaultValue ⟦Ѧ􋉖 􋀭(Ѧᵛ)⟧⍮ max ⟦Ѧʰ⟧⍮ step ⟦Ѧˢ∨‹any›⟧} ‹›;
  ©  = Ѧ􋑵 = 󱀝 input {𝑇 ‹range›⍮ min ⟦Ѧˡ⟧⍮ defaultValue ⟦Ѧ􋉖 􋀭(Ѧᵛ)⟧⍮ max ⟦Ѧʰ⟧⍮ step any} ‹›;
  ᵛᵃˡᵘᵉ = Ѧ􋉖 􋀭(Ѧᵛ);
  
  Ѧ=􀴗={⠤Ѧ,}
  Ѧˢᵉᵗ = ⥌v=󱣩,call=✓↦{
           ¿(v≅󱣩) v = Ѧ􋉖 􋀫(+ᵛᵃˡᵘᵉ);
           ¿(Ѧˢ) v = +(Ѧˢ⋅▢(v÷Ѧˢ)).toFixed(6);
           Ѧᵛ = v;
           ᵛᵃˡᵘᵉ = Ѧ􋉖 􋀭(Ѧᵛ);
           ¿(call) Ѧ􊽺(Ѧᵛ);
           ↪Ѧᵛ; };
  AEL(,‹input›,𝚲Ѧˢᵉᵗ());
  Ѧˢᵉᵗ(󱣩,Ѧⁱⁿⁱᵗ);
  ↪; };

