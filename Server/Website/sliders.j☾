  ɒ = {⠤ɒ,init:✗,ƒ:𝚲Ѧˢᵉᵗ()};
  © s = 󱀝 ⟦əslider⟧ {⠤ɒ};
  
  © len = Ѧ􋕨􋒶􊪸􋕨(ᐦ+ +(Ѧʰ+(Ѧˢ∨0.00001)).toFixed(6))􋌵⋅0.75;
  ⎉ l;
  ©  = 󱀝 {𝐶 sliderLabeled} ⟦[ 󱀝:l T ⦅𝚠 ⟦0.9⋅len⟧em⦆, s ]⟧;
  
  Ѧˢᵉᵗ = ⥌v=󱣩,call=✓↦{
           ¿(v≅󱣩) v = +s􀴗 ᵛ;
           ¡      s􀴗.set(v,✗);
           Ѧᵛ = v;
           l􋒷 = Ѧ􋕨􋒶􊪸􋕨(Ѧᵛ);
           ¿(call) Ѧ􊽺(Ѧᵛ);
           ↪Ѧᵛ; };
  􀴗=Ѧ; Ѧ􋑵=; Ѧˢᵉᵗ(󱣩,Ѧⁱⁿⁱᵗ);
  ↪; };

ədurSlider = ⥌Ѧ={}↦{
