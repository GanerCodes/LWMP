fit_size = ⥌𝐭,w,sz=100,st=ᐦ,Δ=5↦{
  ➰(measureText(𝐭,sz,ᐦ)ʷⁱᵈᵗʰ≥w) sz -= Δ;
  ↪‹font-size:⟦sz⟧px;›; }

𝘋𝘉 = 𝔏𝔖􋀭(‹tokens›,{});
updateDB = 𝚲𝔏𝔖􋀫(‹tokens›,𝘋𝘉);

add_check_tok = ⥌𝐭↦{
  ¿(¬(𝐭∈𝘋𝘉)) { 𝘋𝘉􊳬={ scenes:{}, devs:{} };
               updateDB(); }
  ↪𝘋𝘉􊳬; }
del_tok = ⥌𝐭↦{ 󰆴 𝘋𝘉􊳬;
               updateDB(); }
get_toks     = 󰲟𝒪k(𝘋𝘉)
get_devs     = ⥌𝔱↦add_check_tok(𝔱􋆮).devs
get_scenes   = ⥌𝔱↦add_check_tok(𝔱􋆮).scenes
copy_scene = ⥌𝐭,o,n↦{
  © 𝐒 = add_check_tok(𝐭).scenes;
  ¿(¬(o∈𝐒) ∨ (n∈𝐒)) ↪✗;
  𝐒ₙ = 𝐒󰂼;
  updateDB();
  ↪✓; }
move_scene = ⥌𝐭,o,n=󱣩↦{  blank n for deletion
  © 𝐒 = add_check_tok(𝐭).scenes;
  ¿(¬(o∈𝐒)) ↪✗;
  ¿(n≇󱣩) ¿(¬copy_scene(𝐭,o,n)) ↪✗;
  󰆴 𝐒󰂼;
  updateDB();
  ↪✓; }
add_scene = ⥌𝐭,𝐬,override↦{  𝐬={name,𝐔,󰠲}
  name = 𝐬ⁿᵃᵐᵉ; 𝐬 = {⠤𝐬}; 󰆴 𝐬ⁿᵃᵐᵉ;
  © 𝐒 = add_check_tok(𝐭).scenes;
  ¿(¬override ∧ name∈𝐒) ↪✗
  𝐒ₙₐₘₑ = 𝐬;
  updateDB();
  ↪𝐬; }

load_devices = 󱟱⥌𝔱↦{
  © 𝐋 = add_check_tok(𝔱􋆮);
  © 𝐃o = 𝐋ᵈᵉᵛˢ;
  ⎉ r;
  { r = 󱫬 𝔱.get_devs(); }catch(e){}
  ¿(¬r ∨ ¬r₀ ∨ rˢᵗᵃᵗᵘˢ≠200) ↪𝖡(𝐃o);
  © 𝐃 = r₁;
  𝐋ᵈᵉᵛˢ = {⠤𝐃};
  updateDB();
  ↪𝖦(𝐃); }