𝗉 = 󰲡{ ⎉ r,p = 🆕 Promise(󰲣r=x);
       ↪pʳ=r,p; };
𝘔 = 󰲟{  messenger and awaitor
  © M = [𝗉()];
  © 𝘴 = 𝚲(M􋕛(󷰾)ʳ(𝔸),M.push(𝗉()));
  © 𝘳 = 󱟱󰲟(󰲡(M.shift(),x))(󱫬 M₀)
  ↪[𝘴,𝘳]; };
󰇮 = ⥌ƒ↦𝚲{  bidirectional messages
  © [[𝚂𝘴,𝙲𝘳],[𝙲𝘴,𝚂𝘳]] = [𝘔(),𝘔()]
  ƒ(𝚂𝘴,𝚂𝘳)(⠤𝔸);
  ↪[𝙲𝘴,𝙲𝘳]; };

fit_size = ⥌𝐭,w,sz=100,st=ᐦ,Δ=5↦{
  ➰(measureText(𝐭,sz,ᐦ)ʷⁱᵈᵗʰ≥w) sz -= Δ;
  ↪‹font-size:⟦sz⟧px;›; };

𝘋𝘉 = 𝔏𝔖􋀭("tokens",{})
updateDB = 𝚲𝔏𝔖􋀫("tokens",𝘋𝘉)
get_toks = 󰲟𝒪k(𝘋𝘉)
layout_from_tok = ⥌𝐭↦{
  ¿(¬(𝐭∈𝘋𝘉)) { 𝘋𝘉􊳬={ scenes:{}, devs:{} };
               updateDB(); }
  ↪𝘋𝘉􊳬; }
remove_tok = ⥌𝐭↦{ ☾(‹Deleting token "⟦𝐭⟧"›);
                  󰆴 𝘋𝘉􊳬;
                  updateDB(); };
load_devices = 󱟱 ⥌𝐭↦{
  © 𝐋 = layout_from_tok(𝐭)
  ⎉ r;
  
  try{ r = 󱫬 𝐀(𝐭).get_devs(); }catch(e){}
  ¿(¬r ∨ ¬r₀ ∨ r.status≠200) ↪𝖡(𝐋ᵈᵉᵛˢ);
  𝐋ᵈᵉᵛˢ = { ⠤ᴍv(𝐋ᵈᵉᵛˢ,󰲣[x,{⠤y,offline:✗}]), ⠤r₁ }
  updateDB();
  ↪𝖦(𝐋ᵈᵉᵛˢ); }