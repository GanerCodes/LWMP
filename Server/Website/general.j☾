𝘋𝘉 = 𝔏𝔖􋀭("tokens",{});
updateDB = 𝚲𝔏𝔖􋀫("tokens",𝘋𝘉);

add_check_tok = ⥌𝐭↦{
  ¿(¬(𝐭∈𝘋𝘉)) { 𝘋𝘉􊳬={ scenes:{}, devs:{} };
               updateDB(); }
  ↪𝘋𝘉􊳬; }
del_tok = ⥌𝐭↦{ 󰆴 𝘋𝘉􊳬;
               updateDB(); }
get_toks     = 󰲟𝒪k(𝘋𝘉)
get_devs     = ⥌𝐭↦add_check_tok(𝐭).devs
get_scenes   = ⥌𝐭↦add_check_tok(𝐭).scenes
copy_scene = ⥌𝐭,o,n↦{
  © 𝐒 = add_check_tok(𝐭).scenes;
  ¿(¬(o∈𝐒) ∨ (n∈𝐒)) ↪✗;
  𝐒ₙ = 𝐒󰂼;
  updateDB();
  ↪✓; }
move_scene = ⥌𝐭,o,n=󱣩↦{  blank n for deletion
  © 𝐒 = add_check_tok(𝐭).scenes;
  ¿(¬(o∈𝐒)) ↪✗;
  ¿(n≇󱣩) ¿(¬copy_scene(𝐭,o,n)) ↪✗;
  󰆴 𝐒󰂼;
  updateDB();
  ↪✓; }
add_scene = ⥌𝐭,𝐬,override↦{  name,𝐔,dat
  name = 𝐬ⁿᵃᵐᵉ; 𝐬 = {⠤𝐬}; 󰆴 𝐬ⁿᵃᵐᵉ;
  © 𝐒 = add_check_tok(𝐭).scenes;
  ¿(¬override ∧ name∈𝐒) ↪✗
  𝐒ₙₐₘₑ = 𝐬;
  updateDB();
  ↪𝐬; }

load_devices = 󱟱 ⥌𝐭↦{
  © 𝐋 = add_check_tok(𝐭)
  ⎉ r;
  
  try{ r = 󱫬 𝐀(𝐭).get_devs(); }catch(e){}
  ¿(¬r ∨ ¬r₀ ∨ rˢᵗᵃᵗᵘˢ≠200) ↪𝖡(𝐋ᵈᵉᵛˢ);
  𝐋ᵈᵉᵛˢ = { ⠤ᴍv(𝐋ᵈᵉᵛˢ,󰲡({⠤x,offline:✗})), ⠤r₁ }
  updateDB();
  ↪𝖦(𝐋ᵈᵉᵛˢ); }