Network stuff
  Get CERT.pem by getting middle cert from `openssl s_client -connect example.com:443 -showcerts </dev/null`

  Cloudflare HTTP  ports: 80 8080 8880 2052 2082 2086 2095
  Cloudflare HTTPS ports: 443 2053 2083 2087 2096 8443
  
  Current defaults (External SSL → Internal HTTP)
  Website  : 443  → 4004
  Websocket: 2096 → 4005

Example nginx config snippet
  server {
    listen              443 ssl;
    server_name         lwmp.ganer.xyz;
    access_log          /var/log/nginx/LWMP_website_nrm.log;
    error_log           /var/log/nginx/LWMP_website_err.log;
    ssl_certificate     /etc/nginx/keys/cert.pem;
    ssl_certificate_key /etc/nginx/keys/priv.pem;
    ssl_buffer_size     1400;
    location /          { proxy_pass http://127.0.0.1:4004/;
                          proxy_set_header Host $host;
                          proxy_set_header X-Real-IP $remote_addr; } }
  server {
    listen              2096 ssl;
    server_name         lwmp.ganer.xyz;
    access_log          /var/log/nginx/LWMP_websock_nrm.log;
    error_log           /var/log/nginx/LWMP_websock_err.log;
    ssl_certificate     /etc/nginx/keys/cert.pem;
    ssl_certificate_key /etc/nginx/keys/priv.pem;
    ssl_buffer_size     2k;
    location /          { proxy_pass http://127.0.0.1:4005/;
                          proxy_buffering off;
                          proxy_request_buffering off;
                          proxy_http_version 1.1;
                          proxy_set_header Upgrade $http_upgrade;
                          proxy_set_header Connection $http_connection;
                          proxy_read_timeout 3600s;
                          tcp_nodelay on; } }