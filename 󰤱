docker build -t lwmp .

docker run --privileged --device=/dev/bus/usb \
           --group-add dialout -v /dev:/dev \
           lwmp /bin/bash -c ./flash.sh

mkdir -p /root/LWMP/Data && cd /root/LWMP
docker run --net=host \
           -v "$PWD/Data:/opt/LWMP/Server/Data" \
           lwmp /bin/bash -c "cd Server && ☾ server.☾"